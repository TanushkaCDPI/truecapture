# TrueCapture Backend — Environment Variables
# Copy this file to backend/.env and fill in your values.
# Never commit .env to version control.

# ── DeDi.global key registry ──────────────────────────────────────
# Your API key from https://dedi.global — used to register your public
# signing key on startup so verifiers can look it up independently.
DEDI_API_KEY=your_dedi_api_key_here

# Your DeDi namespace (e.g. "bbc", "reuters", "your-org").
# Created in the DeDi dashboard under your account.
DEDI_NAMESPACE=your-org-namespace

# The registry name within your namespace. Leave as "signing-keys"
# unless you have a specific reason to use a different name.
DEDI_REGISTRY=signing-keys

# ── Your organisation ──────────────────────────────────────────────
# Appears in the C2PA manifest embedded in every signed file.
ORG_NAME=Your Organisation Name

# Your public-facing URL. Appears in the DeDi key record.
ORG_URL=https://yourdomain.com

# ── Verify URL ────────────────────────────────────────────────────
# Base URL for verify links included in signed file metadata.
# Should point to your deployed verify page.
VERIFY_BASE_URL=https://verify.yourdomain.com/verify

# ── Server ────────────────────────────────────────────────────────
# Port the Fastify server listens on. Railway sets PORT automatically.
PORT=3000

# Host to bind. 0.0.0.0 required for Railway / Docker deployments.
HOST=0.0.0.0
